          "name": "Single URL Preview",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://docs.scrt.network/secret-network-documentation/introduction/secret-network-techstack/consensus-for-secret-transactions\",\n  \"strategy\": \"adaptive\",\n  \"chunk_size\": 1000,\n  \"chunk_overlap\": 200,\n  \"max_preview_chunks\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/kb-drafts/preview",
              "host": ["{{base_url}}"],
              "path": ["kb-drafts", "preview"]
            }
          }
        },
        {
          "name": "Draft Preview",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"by_heading\",\n  \"chunk_size\": 1000,\n  \"chunk_overlap\": 200,\n  \"max_preview_pages\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/kb-drafts/{{draft_id}}/preview",
              "host": ["{{base_url}}"],
              "path": ["kb-drafts", "{{draft_id}}", "preview"]
            }
          }
        },
        {
          "name": "Get Draft Pages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/kb-drafts/{{draft_id}}/pages",
              "host": ["{{base_url}}"],
              "path": ["kb-drafts", "{{draft_id}}", "pages"]
            }
          }
        },
        {
          "name": "Get Draft Chunks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/kb-drafts/{{draft_id}}/chunks?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["kb-drafts", "{{draft_id}}", "chunks"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Validate Draft",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/kb-drafts/{{draft_id}}/validate",
              "host": ["{{base_url}}"],
              "path": ["kb-drafts", "{{draft_id}}", "validate"]
            }
          }
        },
        {
          "name": "Finalize Draft",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/kb-drafts/{{draft_id}}/finalize",
              "host": ["{{base_url}}"],
              "path": ["kb-drafts", "{{draft_id}}", "finalize"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('kb_id', response.kb_id);",
                  "    pm.collectionVariables.set('pipeline_id', response.pipeline_id);",
                  "    pm.test('KB finalized', () => {",
                  "        pm.expect(response.kb_id).to.exist;",
                  "        pm.expect(response.pipeline_id).to.exist;",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
