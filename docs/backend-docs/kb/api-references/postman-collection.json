    {
      "name": "Testing Scenarios",
      "item": [
        {
          "name": "Complete KB Creation Flow",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// This is a complete flow test scenario",
                  "console.log('Starting complete KB creation flow test');",
                  "",
                  "// Set test variables",
                  "pm.collectionVariables.set('test_url', 'https://docs.scrt.network/secret-network-documentation/introduction/secret-network-techstack/consensus-for-secret-transactions');",
                  "pm.collectionVariables.set('test_kb_name', 'Test KB ' + Date.now());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Error Scenarios - Invalid Token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "invalid_token_12345",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/kbs/",
              "host": ["{{base_url}}"],
              "path": ["kbs", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401 for invalid token', () => {",
                  "    pm.expect(pm.response.code).to.equal(401);",
                  "});",
                  "",
                  "pm.test('Error response has correct format', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('detail');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Error Scenarios - Nonexistent Resource",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/kbs/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"],
              "path": ["kbs", "00000000-0000-0000-0000-000000000000"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 404 for nonexistent resource', () => {",
                  "    pm.expect(pm.response.code).to.equal(404);",
                  "});",
                  "",
                  "pm.test('Error response has helpful message', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.detail).to.include('not found');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Global pre-request script",
          "console.log('Request: ' + request.method + ' ' + request.url.toString());",
          "",
          "// Check if we have a valid JWT token",
          "const token = pm.collectionVariables.get('jwt_token');",
          "if (!token && request.url.toString().includes('/auth/') === false) {",
          "    console.log('Warning: No JWT token set. Authentication may be required.');",
          "}",
          "",
          "// Add request timestamp",
          "pm.collectionVariables.set('request_timestamp', new Date().toISOString());"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "// Global test script",
          "pm.test('Response time is reasonable', () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(30000);",
          "});",
          "",
          "if (pm.response.code >= 400) {",
          "    console.log('Error response:', pm.response.json());",
          "}",
          "",
          "// Log response details for debugging",
          "console.log('Response:', pm.response.code, pm.response.status);"
        ]
      }
    }
  ]
