            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"by_heading\",\n  \"chunk_size\": 1200,\n  \"chunk_overlap\": 150,\n  \"preserve_code_blocks\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/kb-drafts/{{draft_id}}/chunking",
              "host": ["{{base_url}}"],
              "path": ["kb-drafts", "{{draft_id}}", "chunking"]
            }
          }
        },
