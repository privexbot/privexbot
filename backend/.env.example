# Production Environment Configuration Template
# IMPORTANT: Copy this to .env and update all values before deployment

# Application Settings
PROJECT_NAME=PrivexBot
API_V1_PREFIX=/api/v1
ENVIRONMENT=production

# Database Configuration
# WARNING: Change these credentials for production!
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=postgresql://privexbot:CHANGE_ME_IN_PRODUCTION@postgres:5432/privexbot

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Security & JWT
# CRITICAL: Generate a strong random secret key for production!
# Example: openssl rand -hex 32
SECRET_KEY=GENERATE_STRONG_SECRET_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Credential Encryption (required for credential storage features)
# CRITICAL: Generate a strong Fernet key for production!
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_FERNET_KEY_HERE

# CORS Settings
# Update with your production frontend domain
BACKEND_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Wallet Authentication
NONCE_EXPIRE_SECONDS=300

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email (SMTP) Configuration
# For Gmail: Enable 2FA and generate an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=noreply@privexbot.com
SMTP_FROM_NAME=PrivexBot

# Frontend URL (for invitation links, webhooks, etc.)
# Local: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=https://yourdomain.com


# =============================================================================
# AI Inference Configuration
# =============================================================================
# PrivexBot uses a multi-provider inference system with Secret AI as the
# PRIMARY provider. Secret AI runs on SecretVM (Trusted Execution Environment)
# for privacy-preserving AI inference.
#
# Provider Priority:
# 1. Secret AI (PRIMARY) - Always tried first, privacy-preserving via TEE
# 2. Fallback providers (if enabled and Secret AI fails):
#    - Akash ML (decentralized AI)
#    - Gemini (Google AI)
#    - OpenAI
#    - DeepSeek
#    - Ollama (local, if available)

# Secret AI Configuration (PRIMARY provider)
# Get your API key from Secret Network
SECRET_AI_API_KEY=sk-your-secret-ai-api-key
SECRET_AI_BASE_URL=https://secretai-api-url.scrtlabs.com:443/v1

# SecretVM Detection
# Set to 'true' ONLY when deploying on SecretVM
# When true: Secret AI is guaranteed to work, no fallback needed
# When false: Fallback providers will be used if Secret AI fails
SECRETVM=false

# Fallback Configuration
# Enable to automatically try other providers if Secret AI is unavailable
# Recommended: true for production environments not on SecretVM
# Set to false on SecretVM where Secret AI is guaranteed to work
INFERENCE_FALLBACK_ENABLED=true

# Fallback Provider 1: Akash ML (decentralized AI inference)
# Get API key from: https://akashml.com
AKASHML_API_KEY=your-akash-ml-api-key

# Fallback Provider 2: Gemini (Google AI)
# Get API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Fallback Provider 3: OpenAI (optional)
# Get API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key

# Fallback Provider 4: DeepSeek (optional)
# Get API key from: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=your-deepseek-api-key

# Fallback Provider 5: Ollama (local inference, optional)
# Only used if running Ollama locally
# OLLAMA_BASE_URL=http://localhost:11434/v1

# =============================================================================
# Production Settings
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
