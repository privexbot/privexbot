# Production Environment Configuration Template
# IMPORTANT: Copy this to .env and update all values before deployment

# Application Settings
PROJECT_NAME=PrivexBot
API_V1_PREFIX=/api/v1
ENVIRONMENT=production

# Database Configuration
# WARNING: Change these credentials for production!
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=postgresql+psycopg2://privexbot:CHANGE_ME_IN_PRODUCTION@postgres:5432/privexbot

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Qdrant Vector Database Configuration
QDRANT_URL=http://qdrant:6333

# Tika Document Parsing Configuration
TIKA_URL=http://tika:9998

# Security & JWT
# CRITICAL: Generate a strong random secret key for production!
# Example: openssl rand -hex 32
SECRET_KEY=GENERATE_STRONG_SECRET_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Credential Encryption (required for credential storage features)
# CRITICAL: Generate a strong Fernet key for production!
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_FERNET_KEY_HERE

# CORS Settings
# Update with your production frontend domain
BACKEND_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Wallet Authentication
NONCE_EXPIRE_SECONDS=300

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email (SMTP) Configuration
# For Gmail: Enable 2FA and generate an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=noreply@privexbot.com
SMTP_FROM_NAME=PrivexBot

# Frontend URL (for invitation links, webhooks, etc.)
# Local: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=https://yourdomain.com


# =============================================================================
# MinIO Object Storage Configuration
# =============================================================================
# MinIO provides S3-compatible storage for file uploads (avatars, KB files, chat files)
# CRITICAL: Change credentials for production!
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=privexbot
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_PUBLIC_URL=https://storage.yourdomain.com
MINIO_SECURE=false
# CORS: Comma-separated list of allowed origins for MinIO API access
# This is used by docker-compose.yml to configure MINIO_API_CORS_ALLOW_ORIGIN
# CRITICAL: Do NOT use wildcard (*) in production for security reasons!
MINIO_CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# =============================================================================
# AI Inference Configuration (Decentralized AI Only)
# =============================================================================
# PrivexBot uses Secret AI for privacy-focused inference:
# - Secret AI (PRIMARY) - Privacy-preserving via Trusted Execution Environment

# Secret AI Configuration (PRIMARY provider)
# Get your API key from Secret Network
SECRET_AI_API_KEY=sk-your-secret-ai-api-key
SECRET_AI_BASE_URL=https://secretai-api-url.scrtlabs.com:443/v1

# Use native secret-ai-sdk instead of OpenAI-compatible API
USE_SECRET_AI_SDK=true

# SecretVM Detection
# Set to 'true' ONLY when deploying on SecretVM
SECRETVM=false

# Fallback Configuration
# Currently no fallback providers configured
INFERENCE_FALLBACK_ENABLED=false

# =============================================================================
# Monitoring Configuration
# =============================================================================
# Flower (Celery Monitoring) - used by docker-compose.yml
FLOWER_PASSWORD=CHANGE_ME_STRONG_FLOWER_PASSWORD

# =============================================================================
# Webhook & Integration URLs
# =============================================================================
# Base URL for API webhooks (Telegram, Discord callbacks)
# Must be publicly accessible HTTPS URL
API_BASE_URL=https://api.yourdomain.com/api/v1

# Widget CDN URL (where the chat widget JavaScript is hosted)
# NOTE: Do NOT include /widget.js - the code appends it automatically
WIDGET_CDN_URL=https://cdn.yourdomain.com

# =============================================================================
# Discord Shared Bot Configuration
# =============================================================================
# ONE bot serves ALL customers via guild_id → chatbot_id routing
# To set up Discord integration:
# 1. Go to https://discord.com/developers/applications
# 2. Create a New Application
# 3. Copy the "Application ID" → DISCORD_SHARED_APPLICATION_ID
# 4. Go to "Bot" section → Reset Token → Copy → DISCORD_SHARED_BOT_TOKEN
# 5. Go to "General Information" → Copy "Public Key" → DISCORD_SHARED_PUBLIC_KEY
# 6. In "Bot" section, enable "Message Content Intent" under Privileged Gateway Intents
# 7. In "OAuth2" → "URL Generator", select "bot" and "applications.commands" scopes

DISCORD_SHARED_APPLICATION_ID=
DISCORD_SHARED_BOT_TOKEN=
DISCORD_SHARED_PUBLIC_KEY=

# =============================================================================
# Notion OAuth Integration (Optional)
# =============================================================================
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# =============================================================================
# Google OAuth Integration (Optional - for Google Docs/Sheets KB + Gmail)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Slack Integration (Optional)
# =============================================================================
# 1. Go to https://api.slack.com/apps and create a new app
# 2. Copy Client ID, Client Secret, and Signing Secret from Basic Information
# 3. Set Event Subscriptions URL: {API_BASE_URL}/webhooks/slack/events
# 4. Set OAuth Redirect URL: {API_BASE_URL}/webhooks/slack/oauth/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# =============================================================================
# Calendly Integration (Optional)
# =============================================================================
# 1. Go to https://developer.calendly.com/ and create OAuth app
# 2. Set redirect URI: {API_BASE_URL}/credentials/oauth/callback
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=

# =============================================================================
# Production Settings
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
