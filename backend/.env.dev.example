# Development Environment Configuration Template
# IMPORTANT: Copy this to .env.dev and update values as needed

# Application Settings
PROJECT_NAME=PrivexBot-Dev
API_V1_PREFIX=/api/v1
ENVIRONMENT=development

# Database Configuration (matches docker-compose.dev.yml)
DATABASE_URL=postgresql://privexbot:privexbot_dev@postgres:5432/privexbot_dev
POSTGRES_PASSWORD=privexbot_dev

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Security & JWT (use weak keys for development only)
SECRET_KEY=dev-secret-key-not-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Settings (allow all for development)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Wallet Authentication
NONCE_EXPIRE_SECONDS=600

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2


# Email (SMTP) Configuration
# For Gmail: Enable 2FA and generate an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=privexbotapp@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=noreply@privexbot.com
SMTP_FROM_NAME=PrivexBot


# Frontend URL Configuration
# Used for generating links in emails (password reset, invitations)
FRONTEND_URL=http://localhost:5174

# AI Inference
SECRET_AI_API_KEY=sk-your-secret-ai-api-key


# Development: Enable debug logging
DEBUG=true
LOG_LEVEL=DEBUG
