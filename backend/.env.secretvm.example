# SecretVM Production Environment Configuration
# CRITICAL: Update all sensitive values before deployment!
# Usage: Copy this to /mnt/secure/docker_wd/.env on SecretVM

# Application Settings
PROJECT_NAME=PrivexBot
API_V1_PREFIX=/api/v1
ENVIRONMENT=production

# Database Configuration
# CRITICAL: Generate strong password for production!
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql+psycopg2://privexbot:${POSTGRES_PASSWORD}@postgres:5432/privexbot

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Qdrant Vector Database Configuration
QDRANT_URL=http://qdrant:6333

# Tika Document Parsing Configuration
TIKA_URL=http://tika:9998

# Security & JWT
# CRITICAL: Generate a strong random secret key!
# Generate with: openssl rand -hex 32
SECRET_KEY=GENERATE_STRONG_SECRET_KEY_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Credential Encryption (required for credential storage features)
# CRITICAL: Generate a strong Fernet key for production!
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_FERNET_KEY_HERE

# CORS Settings - SecretVM Production Domains
# Include all SecretVM subdomains and your production frontend
BACKEND_CORS_ORIGINS=https://privexbot.com,https://www.privexbot.com,https://api.privexbot.com,https://pgadmin.privexbot.com,https://redis-ui.privexbot.com,https://traefik.privexbot.com,https://flower.privexbot.com
# Wallet Authentication
NONCE_EXPIRE_SECONDS=300

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email (SMTP) Configuration
# For Gmail: Enable 2FA and generate an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=privexbotapp@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=noreply@privexbot.com
SMTP_FROM_NAME=PrivexBot


# Frontend URL Configuration
# Used for generating links in emails (password reset, invitations)
FRONTEND_URL=https://privexbot.com


# =============================================================================
# AI Inference Configuration (SecretVM - Decentralized AI Only)
# =============================================================================
# On SecretVM, Secret AI is the PRIMARY provider (runs natively with no network restrictions)
# Secret AI: Privacy-preserving via Trusted Execution Environment

# Secret AI Configuration (PRIMARY - Native on SecretVM)
# CRITICAL: Replace with your actual Secret AI API key
SECRET_AI_API_KEY=sk-your-secret-ai-api-key
SECRET_AI_BASE_URL=https://secretai-api-url.scrtlabs.com:443/v1

# Use native secret-ai-sdk for optimal Secret AI integration
USE_SECRET_AI_SDK=true

# SecretVM Detection - MUST be true when running on SecretVM
SECRETVM=true

# Fallback Configuration
# No fallback needed on SecretVM (Secret AI works reliably here)
INFERENCE_FALLBACK_ENABLED=false

# PgAdmin Configuration
PGADMIN_PASSWORD=CHANGE_ME_STRONG_PGADMIN_PASSWORD

# Flower (Celery Monitoring) Configuration
# Used by docker-compose.secretvm.yml for Flower basic auth
FLOWER_PASSWORD=CHANGE_ME_STRONG_FLOWER_PASSWORD

# =============================================================================
# Webhook & Integration URLs
# =============================================================================
# Base URL for API webhooks (Telegram, Discord callbacks)
# Must be publicly accessible HTTPS URL
API_BASE_URL=https://api.privexbot.com/api/v1

# Widget CDN URL (where the chat widget JavaScript is hosted)
# Options: https://widget.privexbot.com or external CDN
WIDGET_CDN_URL=https://widget.privexbot.com

# =============================================================================
# Discord Shared Bot Configuration
# =============================================================================
# ONE bot serves ALL customers via guild_id → chatbot_id routing
# To set up Discord integration:
# 1. Go to https://discord.com/developers/applications
# 2. Create a New Application
# 3. Copy the "Application ID" → DISCORD_SHARED_APPLICATION_ID
# 4. Go to "Bot" section → Reset Token → Copy → DISCORD_SHARED_BOT_TOKEN
# 5. Go to "General Information" → Copy "Public Key" → DISCORD_SHARED_PUBLIC_KEY
# 6. In "Bot" section, enable "Message Content Intent" under Privileged Gateway Intents
# 7. In "OAuth2" → "URL Generator", select "bot" and "applications.commands" scopes

DISCORD_SHARED_APPLICATION_ID=
DISCORD_SHARED_BOT_TOKEN=
DISCORD_SHARED_PUBLIC_KEY=

# Production Settings
DEBUG=false
LOG_LEVEL=INFO

# PrivexBot Production Deployment Information
# Domain: privexbot.com
# API: https://api.privexbot.com
# Frontend: https://privexbot.com
# PgAdmin: https://pgadmin.privexbot.com
# Redis UI: https://redis-ui.privexbot.com
# Flower (Celery): https://flower.privexbot.com
# Traefik: https://traefik.privexbot.com