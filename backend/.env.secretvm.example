# SecretVM Production Environment Configuration
# CRITICAL: Update all sensitive values before deployment!
# Usage: Copy this to /mnt/secure/docker_wd/.env on SecretVM

# Application Settings
PROJECT_NAME=PrivexBot
API_V1_PREFIX=/api/v1
ENVIRONMENT=production

# Database Configuration
# CRITICAL: Generate strong password for production!
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://privexbot:${POSTGRES_PASSWORD}@postgres:5432/privexbot

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Security & JWT
# CRITICAL: Generate a strong random secret key!
# Generate with: openssl rand -hex 32
SECRET_KEY=GENERATE_STRONG_SECRET_KEY_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings - SecretVM Production Domains
# Include all SecretVM subdomains and your production frontend
# BACKEND_CORS_ORIGINS=https://sapphire-finch.vm.scrtlabs.com,https://api.sapphire-finch.vm.scrtlabs.com,https://app.yourdomain.com,https://www.yourdomain.com
BACKEND_CORS_ORIGINS=https://harystyles.store,https://api.harystyles.store
# Wallet Authentication
NONCE_EXPIRE_SECONDS=300

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email (SMTP) Configuration
# For Gmail: Enable 2FA and generate an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=privexbotapp@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=noreply@privexbot.com
SMTP_FROM_NAME=PrivexBot


# Frontend URL Configuration
# Used for generating links in emails (password reset, invitations)
FRONTEND_URL=http://localhost:5174


# PgAdmin Configuration
PGADMIN_PASSWORD=CHANGE_ME_STRONG_PGADMIN_PASSWORD

# Production Settings
DEBUG=false
LOG_LEVEL=INFO

# SecretVM Network Information
# IP: 67.43.239.18
# Base Domain: sapphire-finch.vm.scrtlabs.com
# API: https://api.sapphire-finch.vm.scrtlabs.com
# PgAdmin: https://pgadmin.sapphire-finch.vm.scrtlabs.com
# Redis UI: https://redis-ui.sapphire-finch.vm.scrtlabs.com
# Traefik: https://traefik.sapphire-finch.vm.scrtlabs.com
