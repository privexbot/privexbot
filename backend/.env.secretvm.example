# SecretVM Production Environment Configuration Template
# CRITICAL: Update all sensitive values before deployment!
# Usage: Copy this to deploy/secretvm/.env and fill in credentials
#        OR create .env.secretvm.local with real credentials (preferred)
#
# The secretvm-deploy.sh prepare command will:
#   1. Use .env.secretvm.local if it exists (contains real credentials)
#   2. Otherwise copy this template to deploy/secretvm/.env

# =============================================================================
# Docker/Container Environment Variables
# =============================================================================
# These are used by docker-compose services for proper container operation
PLAYWRIGHT_BROWSERS_PATH=/app/cache/ms-playwright
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
HF_HOME=/app/cache/huggingface
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
NUMEXPR_NUM_THREADS=1
PYTHONPATH=/app/src
C_FORCE_ROOT=1
OCR_STRATEGY=ocr_and_text
QDRANT__SERVICE__GRPC_PORT=6334

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_USER=privexbot
POSTGRES_DB=privexbot
# CRITICAL: Generate strong password for production!
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql+psycopg2://privexbot:${POSTGRES_PASSWORD}@postgres:5432/privexbot

# =============================================================================
# PgAdmin Configuration
# =============================================================================
PGADMIN_DEFAULT_EMAIL=privexbot@gmail.com
PGADMIN_DEFAULT_PASSWORD=${PGADMIN_PASSWORD}
PGADMIN_CONFIG_SERVER_MODE=True
PGADMIN_LISTEN_PORT=80
PGADMIN_CONFIG_PROXY_X_FOR_COUNT=1
PGADMIN_CONFIG_PROXY_X_PROTO_COUNT=1
PGADMIN_CONFIG_PROXY_X_HOST_COUNT=1
PGADMIN_CONFIG_ENHANCED_COOKIE_PROTECTION=False
# CRITICAL: Generate strong password for production!
PGADMIN_PASSWORD=CHANGE_ME_STRONG_PGADMIN_PASSWORD

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOSTS=local:redis:6379

# =============================================================================
# Qdrant Vector Database Configuration
# =============================================================================
QDRANT_URL=http://qdrant:6333

# =============================================================================
# Tika Document Parsing Configuration
# =============================================================================
TIKA_URL=http://tika:9998

# =============================================================================
# Application Settings
# =============================================================================
PROJECT_NAME=PrivexBot
API_V1_PREFIX=/api/v1
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# Security & JWT
# =============================================================================
# CRITICAL: Generate a strong random secret key!
# Generate with: openssl rand -hex 32
SECRET_KEY=GENERATE_STRONG_SECRET_KEY_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Credential Encryption
# =============================================================================
# CRITICAL: Generate a strong Fernet key for production!
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_FERNET_KEY_HERE

# =============================================================================
# CORS Settings
# =============================================================================
# Include all SecretVM subdomains and your production frontend
BACKEND_CORS_ORIGINS=https://privexbot.com,https://www.privexbot.com,https://api.privexbot.com,https://pgadmin.privexbot.com,https://redis-ui.privexbot.com,https://traefik.privexbot.com,https://flower.privexbot.com

# =============================================================================
# Wallet Authentication
# =============================================================================
NONCE_EXPIRE_SECONDS=300

# =============================================================================
# Celery Configuration
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# =============================================================================
# Email (SMTP) Configuration
# =============================================================================
# For Gmail: Enable 2FA and generate an App Password
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
SMTP_FROM_EMAIL=noreply@privexbot.com
SMTP_FROM_NAME=PrivexBot

# =============================================================================
# Frontend URL Configuration
# =============================================================================
# Used for generating links in emails (password reset, invitations)
FRONTEND_URL=https://privexbot.com

# =============================================================================
# AI Inference Configuration (SecretVM)
# =============================================================================
# On SecretVM, Secret AI is the PRIMARY provider (privacy-preserving via TEE)
# CRITICAL: Replace with your actual Secret AI API key
SECRET_AI_API_KEY=sk-your-secret-ai-api-key
SECRET_AI_BASE_URL=https://secretai-api-url.scrtlabs.com:443/v1
# Use native secret-ai-sdk for optimal Secret AI integration
USE_SECRET_AI_SDK=true
# SecretVM Detection - MUST be true when running on SecretVM
SECRETVM=true
# No fallback needed on SecretVM (Secret AI works reliably here)
INFERENCE_FALLBACK_ENABLED=false

# =============================================================================
# MinIO Object Storage Configuration
# =============================================================================
# MinIO provides S3-compatible storage for file uploads (avatars, KB files)
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=privexbot
# CRITICAL: Change password for production!
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_API_CORS_ALLOW_ORIGIN=https://privexbot.com,https://api.privexbot.com
# Public URL for MinIO (used for generating avatar/file URLs)
# SecretVM uses Traefik routing to storage.privexbot.com
MINIO_PUBLIC_URL=https://storage.privexbot.com
# Use TLS for internal MinIO connection (TLS handled by Traefik externally)
MINIO_SECURE=false

# =============================================================================
# Flower (Celery Monitoring) Configuration
# =============================================================================
# Used by docker-compose.secretvm.yml for Flower basic auth
# CRITICAL: Generate strong password for production!
FLOWER_PASSWORD=CHANGE_ME_STRONG_FLOWER_PASSWORD

# =============================================================================
# Webhook & Integration URLs
# =============================================================================
# Base URL for API webhooks (Telegram, Discord callbacks)
# Must be publicly accessible HTTPS URL
API_BASE_URL=https://api.privexbot.com/api/v1
# Widget CDN URL (where the chat widget JavaScript is hosted)
WIDGET_CDN_URL=https://widget.privexbot.com

# =============================================================================
# Discord Shared Bot Configuration
# =============================================================================
# ONE bot serves ALL customers via guild_id → chatbot_id routing
# To set up Discord integration:
# 1. Go to https://discord.com/developers/applications
# 2. Create a New Application
# 3. Copy the "Application ID" → DISCORD_SHARED_APPLICATION_ID
# 4. Go to "Bot" section → Reset Token → Copy → DISCORD_SHARED_BOT_TOKEN
# 5. Go to "General Information" → Copy "Public Key" → DISCORD_SHARED_PUBLIC_KEY
# 6. In "Bot" section, enable "Message Content Intent" under Privileged Gateway Intents
# 7. In "OAuth2" → "URL Generator", select "bot" and "applications.commands" scopes
DISCORD_SHARED_APPLICATION_ID=
DISCORD_SHARED_BOT_TOKEN=
DISCORD_SHARED_PUBLIC_KEY=

# =============================================================================
# Notion OAuth Integration (Optional)
# =============================================================================
# To enable Notion integration for Knowledge Bases:
# 1. Go to https://www.notion.so/my-integrations
# 2. Create a new "Public" integration (not Internal)
# 3. Under "OAuth Domain & URIs", add redirect URI:
#    https://api.privexbot.com/api/v1/credentials/oauth/callback
#    (This is automatically derived from API_BASE_URL above)
# 4. Copy "OAuth client ID" and "OAuth client secret" below
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# =============================================================================
# Google OAuth Integration (Optional)
# =============================================================================
# To enable Google Docs/Sheets integration for Knowledge Bases:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a project (or select existing)
# 3. Enable APIs: Google Drive API, Google Docs API, Google Sheets API
# 4. Create OAuth 2.0 Client ID (Web application type)
# 5. Add authorized redirect URI:
#    https://api.privexbot.com/api/v1/credentials/oauth/callback
#    (This is automatically derived from API_BASE_URL above)
# 6. Copy "Client ID" and "Client secret" below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# =============================================================================
# Slack Integration (Optional)
# =============================================================================
# 1. Go to https://api.slack.com/apps and create a new app
# 2. Copy Client ID, Client Secret, and Signing Secret from Basic Information
# 3. Set Event Subscriptions URL: https://api.privexbot.com/api/v1/webhooks/slack/events
# 4. Set OAuth Redirect URL: https://api.privexbot.com/api/v1/webhooks/slack/oauth/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=


# =============================================================================
# Calendly Integration (Optional)
# =============================================================================
# 1. Go to https://developer.calendly.com/ and create OAuth app
# 2. Set redirect URI: https://api.privexbot.com/api/v1/credentials/oauth/callback
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=


# =============================================================================
# PrivexBot Production Deployment Information
# =============================================================================
# Domain: privexbot.com
# Endpoints:
#   - Frontend:  https://privexbot.com
#   - API:       https://api.privexbot.com
#   - API Docs:  https://api.privexbot.com/api/docs
#   - PgAdmin:   https://pgadmin.privexbot.com
#   - Redis UI:  https://redis-ui.privexbot.com
#   - Flower:    https://flower.privexbot.com
#   - Traefik:   https://traefik.privexbot.com
#   - Storage:   https://storage.privexbot.com
#   - MinIO UI:  https://minio.privexbot.com
