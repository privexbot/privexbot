# Development Environment Configuration Template
# Copy this file to .env.dev for local development

# Backend API URL
# When running with npm: http://localhost:8000/api/v1
# When running with Docker: http://backend-dev:8000/api/v1 (set in docker-compose.dev.yml)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Widget CDN URL (local widget dev server)
VITE_WIDGET_CDN_URL=http://localhost:9000

# Environment name
VITE_ENV=development

# Application Settings
VITE_APP_NAME=PrivexBot-Dev
VITE_APP_VERSION=0.0.1-dev

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
