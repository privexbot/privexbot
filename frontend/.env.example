# Production Environment Configuration Template
# IMPORTANT: Copy this to .env.production and update values before building

# Backend API URL
# Must match your backend deployment URL
VITE_API_BASE_URL=https://api.yourdomain.com/api/v1

# Widget CDN URL (where the chat widget JavaScript is hosted)
VITE_WIDGET_CDN_URL=https://cdn.yourdomain.com/widget

# Environment
VITE_ENV=production

# Application Settings
VITE_APP_NAME=PrivexBot
VITE_APP_VERSION=1.0.0

# Feature Flags (optional)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
