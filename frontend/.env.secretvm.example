# SecretVM Frontend Environment Configuration Template
#
# IMPORTANT: Frontend uses TWO types of configuration:
#
# 1. BUILD-TIME (VITE_*) - Baked into JavaScript bundle during Docker build
#    - Copy this file to .env.secretvm
#    - Dockerfile.secretvm copies .env.secretvm → .env.production
#    - Changes require: Docker image rebuild
#
# 2. RUNTIME (Non-VITE) - Generated at container startup by docker-entrypoint.sh
#    - Copy runtime variables to deploy/secretvm/.env
#    - On SecretVM: /mnt/secure/docker_wd/frontend/usr/.env
#    - Changes require: Container restart only (no rebuild)
#
# The app prioritizes RUNTIME over BUILD-TIME, allowing same image in different envs

# =============================================================================
# BUILD-TIME VARIABLES (VITE_*)
# =============================================================================
# These are compiled into the JavaScript bundle during `npm run build`
# Used as FALLBACK if runtime config is not available

# Backend API URL
VITE_API_BASE_URL=https://api.privexbot.com/api/v1

# Widget CDN URL (where the chat widget JavaScript is hosted)
VITE_WIDGET_CDN_URL=https://widget.privexbot.com

# Environment identifier (code expects VITE_ENV, not VITE_ENVIRONMENT)
VITE_ENV=production

# Application Settings
VITE_APP_NAME=PrivexBot
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false

# =============================================================================
# RUNTIME VARIABLES (Non-VITE)
# =============================================================================
# These are read by docker-entrypoint.sh to generate /config.js at startup
# Takes PRIORITY over build-time variables in production
# Copy these to deploy/secretvm/.env

# Backend API URL (runtime override)
API_BASE_URL=https://api.privexbot.com/api/v1

# Widget CDN URL (runtime override)
WIDGET_CDN_URL=https://widget.privexbot.com

# Environment
ENVIRONMENT=production

# =============================================================================
# Deployment Notes
# =============================================================================
# Build: ./scripts/docker/build-push-secretvm.sh <version>
#
# On SecretVM, the runtime .env file should be at:
#   /mnt/secure/docker_wd/frontend/usr/.env
#
# The docker-compose.secretvm.yml references it as:
#   env_file:
#     - usr/.env
